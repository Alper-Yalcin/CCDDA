# GitHub Models token (LLM aciklamasi icin)
# Token: https://github.com/settings/tokens (fine-grained, "models:read" yetkisi)
GITHUB_TOKEN=

# Opsiyonel: kullanilacak model (default gpt-4o-mini)
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://models.inference.ai.azure.com

# API server ayarlari
CCDDA_CHECKPOINT=artifacts/v1_backend/train/checkpoints/best.pt
CCDDA_DEVICE=cpu
